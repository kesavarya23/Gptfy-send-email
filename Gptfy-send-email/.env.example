# Stable session secret (required in production for OAuth; set on Vercel)
FLASK_SECRET_KEY=replace_with_long_random_string

# Public site URL (optional; used if redirect URLs are not set)
PUBLIC_BASE_URL=https://your-app.vercel.app

# --- Google OAuth (Gmail API send) ---
# Create OAuth client: https://console.cloud.google.com/apis/credentials
# Add authorized redirect: https://YOUR_DOMAIN/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT=https://localhost:5000/api/auth/google/callback

# --- Microsoft OAuth (Outlook / Microsoft 365 via Graph) ---
# Register app: https://go.microsoft.com/fwlink/?linkid=2083908
# Add redirect: https://YOUR_DOMAIN/api/auth/outlook/callback
# API permissions: Mail.Send, User.Read, offline_access, openid
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Use "common" for work/school + personal, or your tenant id
MICROSOFT_TENANT=common
MICROSOFT_OAUTH_REDIRECT=https://localhost:5000/api/auth/outlook/callback

# Optional: path to Tesseract OCR binary (for screenshot text extraction on the server)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# --- SMTP (used when the UI is on "SMTP (password)")
# Default in code is Gmail (smtp.gmail.com:587). For Microsoft, set both:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# Personal @outlook.com / @hotmail.com / @live.com often use:
# SMTP_HOST=smtp-mail.outlook.com
